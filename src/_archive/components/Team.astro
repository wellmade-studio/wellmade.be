---
const team = [
  { name: 'Olivia', role: 'Account Manager', linkedin: 'https://www.linkedin.com/in/oliviadc/' },
  { name: 'Guylian', role: 'Full-Stack Developer', linkedin: 'https://www.linkedin.com/in/guyliancox/' },
  { name: 'François', role: 'Full-Stack Developer', linkedin: 'https://www.linkedin.com/in/francoisdispaux/' },
  { name: 'Jean-Christophe', role: 'Founder', linkedin: 'https://www.linkedin.com/in/totophe/' },
  { name: 'Eric', role: 'Founder', linkedin: 'https://www.linkedin.com/in/erodriguez/' },
];
---

<section id="team" class="py-20 px-6 bg-light/30">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-title text-center mb-6">
      Wellmade <span class="relative inline-block">
        tailors.
        <span class="absolute left-0 right-0 bottom-1 h-2 bg-accent -z-10 rounded-full"></span>
      </span>
    </h2>
    <p class="text-body text-center text-lg max-w-2xl mx-auto mb-16">
      A multidisciplinary team to help our clients with the most complete team to grow their project.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
      {team.map((member) => (
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-accent/30 flex items-center justify-center">
            <span class="text-2xl font-bold text-primary">{member.name.charAt(0)}</span>
          </div>
          <h3 class="font-bold text-title">{member.name}</h3>
          <p class="text-body text-sm mb-2">{member.role}</p>
          <a href={member.linkedin} target="_blank" rel="noopener" class="text-primary hover:underline text-sm">
            LinkedIn
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
