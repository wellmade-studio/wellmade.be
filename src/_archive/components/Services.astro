---
const services = [
  {
    title: 'Strategy',
    items: ['Project strategy', 'Business Modeling', 'Design thinking', 'Go-to-market strategy'],
  },
  {
    title: 'Ideation',
    items: ['Workshops', 'Co-creation', 'Rapid prototyping', 'Design sprints'],
  },
  {
    title: 'Design',
    items: ['UX Design', 'UI Design', 'Product & Services'],
  },
  {
    title: 'Development',
    items: ['Mobile apps', 'Business apps', 'Hardware', 'Infrastructure'],
  },
];
---

<section id="services" class="py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-title text-center mb-16">
      Our <span class="relative inline-block">
        services.
        <span class="absolute left-0 right-0 bottom-1 h-2 bg-accent -z-10 rounded-full"></span>
      </span>
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, i) => (
        <div class="bg-primary text-white rounded-xl p-8 relative overflow-hidden">
          <span class="absolute top-4 left-6 text-6xl font-bold text-white/10">{i + 1}</span>
          <h3 class="text-xl font-bold mb-6 relative z-10">{service.title}</h3>
          <ul class="space-y-3 relative z-10">
            {service.items.map((item) => (
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 flex-shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
