---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Wellmade - Products that work. Teams that deliver.',
  description = 'We build products that matter. Production-ready from day one. Built to evolve.',
  image = '/brand/Wellmade-color.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Wellmade',
  url: 'https://wellmade.be',
  logo: 'https://wellmade.be/brand/Wellmade-color.png',
  description: 'We build products that matter. Production-ready from day one. Built to evolve.',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wellmade" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Indie+Flower&family=Josefin+Sans:wght@100;300;400;500;600;700&display=swap" rel="stylesheet" />

    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="5658f619-1144-4e24-ba6c-50de61246d8a"></script>
  </head>
  <body class="min-h-screen bg-white text-body antialiased font-sans text-lg">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  * {
    box-sizing: border-box;
  }

  /* Section background patterns for visual separation */
  .section-light,
  .section-alt,
  .section-primary,
  .section-accent {
    position: relative;
    overflow: hidden;
  }

  /* Ensure direct content children sit above decorative backgrounds */
  .section-light > *,
  .section-alt > *,
  .section-primary > *,
  .section-accent > * {
    position: relative;
    z-index: 1;
  }

  .section-light {
    @apply bg-white;
  }

  .section-alt {
    @apply bg-light/30;
  }

  .section-primary {
    @apply bg-primary text-white;
    background-image: radial-gradient(circle, rgba(177, 229, 242, 0.18) 1.5px, transparent 1.5px);
    background-size: 36px 36px;
    background-position: 0 0;
  }

  .section-accent {
    @apply bg-accent/10;
  }

  /* Opt-in dot grid for light sections */
  .section-light.has-dots,
  .section-alt.has-dots,
  .section-accent.has-dots {
    background-image: radial-gradient(circle, rgba(71, 68, 107, 0.14) 1.25px, transparent 1.25px);
    background-size: 28px 28px;
    background-position: 0 0;
  }

  /* Decorative crisp SVG blobs - add .has-blobs to a section to enable */
  .has-blobs::before,
  .has-blobs::after {
    content: '';
    position: absolute;
    pointer-events: none;
    z-index: 0;
    background-repeat: no-repeat;
    background-size: contain;
  }

  .has-blobs::before {
    top: -80px;
    right: -120px;
    width: 520px;
    height: 520px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 500 500'><path fill='%23B1E5F2' fill-opacity='0.35' d='M421,301Q387,352,338,383Q289,414,232,411Q175,408,128,374Q81,340,71,282Q61,224,85,171Q109,118,162,92Q215,66,274,73Q333,80,381,114Q429,148,441,199Q453,250,421,301Z'/></svg>");
  }

  .has-blobs::after {
    bottom: -160px;
    left: -140px;
    width: 460px;
    height: 460px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 500 500'><path fill='%23E8E9F3' fill-opacity='0.7' d='M437,295Q409,340,371,375Q333,410,280,418Q227,426,174,402Q121,378,90,329Q59,280,66,224Q73,168,112,128Q151,88,207,74Q263,60,316,84Q369,108,406,148Q443,188,448,219Q453,250,437,295Z'/></svg>");
  }

  .section-primary.has-blobs::before {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 500 500'><path fill='%23B1E5F2' fill-opacity='0.12' d='M421,301Q387,352,338,383Q289,414,232,411Q175,408,128,374Q81,340,71,282Q61,224,85,171Q109,118,162,92Q215,66,274,73Q333,80,381,114Q429,148,441,199Q453,250,421,301Z'/></svg>");
  }

  .section-primary.has-blobs::after {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 500 500'><path fill='%23B1E5F2' fill-opacity='0.08' d='M437,295Q409,340,371,375Q333,410,280,418Q227,426,174,402Q121,378,90,329Q59,280,66,224Q73,168,112,128Q151,88,207,74Q263,60,316,84Q369,108,406,148Q443,188,448,219Q453,250,437,295Z'/></svg>");
  }
</style>
