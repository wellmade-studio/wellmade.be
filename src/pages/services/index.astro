---
import Layout from '../../layouts/Layout.astro';
import Tagline from '../../components/Tagline.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';

const services = [
  {
    title: 'Product Development',
    tagline: 'From idea to production-ready product.',
    description: 'MVPs that aren\'t throwaway demos - real products, built to evolve. We ship working software early and often.',
    href: '/services/product-development',
    icon: 'product' as const,
  },
  {
    title: 'AI Integration',
    tagline: 'Intelligence that works. Not buzzwords.',
    description: 'Adding AI to existing products, or building AI-native from the ground up. Practical AI that solves real problems.',
    href: '/services/ai-integration',
    icon: 'ai' as const,
  },
  {
    title: 'DevOps & Infrastructure',
    tagline: 'Your cloud. Your repos. Your control.',
    description: 'We build, deploy, and manage infrastructure that scales with you. Everything scripted, versioned, documented.',
    href: '/services/devops-infrastructure',
    icon: 'devops' as const,
  },
  {
    title: 'Discovery & Strategy',
    tagline: 'Not sure what to build? Let\'s find out.',
    description: 'We figure it out together - by building, not by writing documents nobody reads. Prototypes, not PowerPoints.',
    href: '/services/discovery-strategy',
    icon: 'discovery' as const,
  },
  {
    title: 'Rescue & Refactor',
    tagline: 'Stuck? We unstick things.',
    description: 'Product broken. Team gone. Technical debt strangling every new feature. We\'ve seen it. We fix it.',
    href: '/services/rescue-refactor',
    icon: 'rescue' as const,
  },
];
---

<Layout title="Services - Wellmade" description="We're builders. From product development to AI integration, DevOps to rescue missions.">
  <!-- Hero -->
  <section class="section-primary has-blobs py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8">What we build.</h1>
      <p class="text-lg md:text-xl text-white/80">
        We're builders. Here's what that looks like in practice.
      </p>
      <p class="text-lg md:text-xl text-white/80 mt-4">
        Every engagement is different, but our services fall into five areas. Most projects combine several. That's normal - real products don't fit neat boxes.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid gap-8">
        {services.map((service, index) => (
          <a
            href={service.href}
            class:list={[
              "group block p-8 md:p-12 rounded-2xl transition-all",
              index % 2 === 0 ? "bg-white shadow-card hover:shadow-lg" : "bg-light/50 hover:bg-light"
            ]}
          >
            <div class="md:flex md:items-start md:justify-between md:gap-8">
              <div class="md:flex-shrink-0 mb-4 md:mb-0 md:mr-2">
                <ServiceIcon name={service.icon} class="w-12 h-12 text-primary group-hover:scale-110 transition-transform" />
              </div>
              <div class="md:flex-1">
                <h2 class="text-2xl md:text-3xl font-bold text-title mb-2 group-hover:text-primary transition-colors">
                  {service.title}
                </h2>
                <p class="text-lg text-primary font-medium mb-4">{service.tagline}</p>
                <p class="text-body text-lg">{service.description}</p>
              </div>
              <div class="mt-6 md:mt-0 md:flex-shrink-0">
                <span class="inline-flex items-center text-primary font-semibold group-hover:translate-x-2 transition-transform">
                  Learn more
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How We Work Together -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-8">How we work together.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-6">
        We work in days. Simple, transparent, no surprises.
      </p>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-8">
        Prepaid buckets, monthly retainers, or time & materials - whatever fits your situation. No fixed quotes. Building products isn't like ordering furniture.
      </p>
      <a href="/working-with-us" class="inline-flex items-center text-primary font-semibold hover:text-primary/70 transition-colors group">
        See how we work
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Not Sure Where to Start -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-6">Not sure where to start?</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-10">
        That's fine. Most conversations start with "we have this idea" or "we have this problem."
      </p>
      <a href="/contact" class="inline-block bg-primary text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-primary/90 transition-colors">
        Let's talk
      </a>
    </div>
  </section>

  <Tagline />
</Layout>
