---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found - Wellmade" description="The page you're looking for doesn't exist or has moved.">
  <section class="section-light has-blobs has-dots py-20 md:py-32 min-h-[70vh] flex items-center">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-primary font-semibold text-lg md:text-xl mb-4">404</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-title leading-tight mb-6">
        This page took<br />
        <span class="text-primary">a wrong turn.</span>
      </h1>
      <p class="text-xl md:text-2xl text-body mb-10 max-w-2xl mx-auto">
        The page you're looking for doesn't exist, or it moved somewhere we haven't documented yet.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="inline-block bg-primary text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-primary/90 transition-colors">
          Back home
        </a>
        <a href="/contact" class="inline-block bg-white text-title px-8 py-4 rounded-full font-semibold text-lg shadow-card hover:shadow-lg transition-shadow">
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
