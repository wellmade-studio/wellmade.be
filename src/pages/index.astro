---
import Layout from '../layouts/Layout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="section-light has-blobs has-dots py-20 md:py-32">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-title leading-tight mb-6">
        Products that work.<br />
        <span class="text-primary">Teams that deliver.</span>
      </h1>
      <p class="text-xl md:text-2xl text-body mb-10 max-w-2xl mx-auto">
        We build products that matter. Production-ready from day one. Built to evolve.
      </p>
      <a href="/contact" class="inline-block bg-primary text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-primary/90 transition-colors">
        Let's talk
      </a>
    </div>
  </section>

  <!-- We Get It Section -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-8">We get it.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-8">
        You've been here before. The endless meetings. The layers of managers. The demos that looked great but never became real products.
      </p>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-8">
        We exist because we've been on your side of that table. And we got tired of it too.
      </p>
      <a href="/manifesto" class="inline-flex items-center text-primary font-semibold hover:text-primary/70 transition-colors group">
        Read our manifesto
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-12">What we do.</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
        <a href="/services/product-development" class="group block p-6 bg-white rounded-2xl shadow-card hover:shadow-lg transition-shadow">
          <ServiceIcon name="product" class="w-10 h-10 text-primary mb-4 group-hover:scale-110 transition-transform" />
          <h3 class="text-xl font-bold text-title mb-3 group-hover:text-primary transition-colors">Product Development</h3>
          <p class="text-body">From idea to production. MVPs that aren't throwaway demos.</p>
        </a>

        <a href="/services/ai-integration" class="group block p-6 bg-white rounded-2xl shadow-card hover:shadow-lg transition-shadow">
          <ServiceIcon name="ai" class="w-10 h-10 text-primary mb-4 group-hover:scale-110 transition-transform" />
          <h3 class="text-xl font-bold text-title mb-3 group-hover:text-primary transition-colors">AI Integration</h3>
          <p class="text-body">Intelligence that works. Not buzzwords.</p>
        </a>

        <a href="/services/devops-infrastructure" class="group block p-6 bg-white rounded-2xl shadow-card hover:shadow-lg transition-shadow">
          <ServiceIcon name="devops" class="w-10 h-10 text-primary mb-4 group-hover:scale-110 transition-transform" />
          <h3 class="text-xl font-bold text-title mb-3 group-hover:text-primary transition-colors">DevOps & Infrastructure</h3>
          <p class="text-body">Your cloud. Your control. Fully managed.</p>
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-8 lg:max-w-[66%] lg:mx-auto mb-12">
        <a href="/services/discovery-strategy" class="group block p-6 bg-white rounded-2xl shadow-card hover:shadow-lg transition-shadow">
          <ServiceIcon name="discovery" class="w-10 h-10 text-primary mb-4 group-hover:scale-110 transition-transform" />
          <h3 class="text-xl font-bold text-title mb-3 group-hover:text-primary transition-colors">Discovery & Strategy</h3>
          <p class="text-body">Not sure what to build? Let's find out - by building.</p>
        </a>

        <a href="/services/rescue-refactor" class="group block p-6 bg-white rounded-2xl shadow-card hover:shadow-lg transition-shadow">
          <ServiceIcon name="rescue" class="w-10 h-10 text-primary mb-4 group-hover:scale-110 transition-transform" />
          <h3 class="text-xl font-bold text-title mb-3 group-hover:text-primary transition-colors">Rescue & Refactor</h3>
          <p class="text-body">Stuck? We unstick things.</p>
        </a>
      </div>

      <a href="/services" class="inline-flex items-center text-primary font-semibold hover:text-primary/70 transition-colors group">
        See all services
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Your Money Builds Product Section -->
  <section class="section-primary has-blobs py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Your money builds product, not org charts.</h2>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10">
        You'll have a point of contact. You'll have project management. But they're here to support the work, not to shield you from it.
      </p>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-12">
        You talk to builders. The people managing your project are the people building your product.
      </p>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div>
          <h3 class="text-lg font-bold text-accent mb-3">Startup roots, enterprise standards.</h3>
          <p class="text-white/70">We've delivered for law firms, publishers, SMEs, and funded startups. Same rigor across the board.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-accent mb-3">AI-native methods.</h3>
          <p class="text-white/70">Not as a sales pitch. Because it lets us deliver more with less overhead.</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-accent mb-3">Your infrastructure, your code.</h3>
          <p class="text-white/70">Always. No lock-in. You stay because we're good, not because you're stuck.</p>
        </div>
      </div>

      <a href="/approach" class="inline-flex items-center text-accent font-semibold hover:text-white transition-colors group">
        How we work
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Work With Us Section -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-12">Work with us.</h2>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-title mb-3">Direct.</h3>
          <p class="text-body">You have a project, we build it together.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-title mb-3">With agencies.</h3>
          <p class="text-body">We partner, we integrate, we ship. Your client, our craft.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-title mb-3">Flexible.</h3>
          <p class="text-body">Days-based, transparent, no surprises.</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="/working-with-us" class="inline-flex items-center text-primary font-semibold hover:text-primary/70 transition-colors group">
          How we work together
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <span class="text-body/50">|</span>
        <a href="/partnerships" class="inline-flex items-center text-primary font-semibold hover:text-primary/70 transition-colors group">
          Partnerships
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Let's Talk Section -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-6">Let's talk.</h2>
      <p class="text-lg md:text-xl text-body leading-relaxed mb-10">
        No pitch deck needed. Most conversations start with "we have this thing we need to build" or "we have this mess we need to fix."
      </p>
      <p class="text-lg text-body mb-10">Let's see if there's a fit.</p>
      <a href="/contact" class="inline-block bg-primary text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-primary/90 transition-colors">
        Get in touch
      </a>
    </div>
  </section>

  <!-- Tagline -->
  <section class="section-accent py-12">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-primary font-cursive text-2xl md:text-3xl">Innovation with a vision.</p>
    </div>
  </section>
</Layout>
