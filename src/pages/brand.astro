---
import Layout from '../layouts/Layout.astro';
import Tagline from '../components/Tagline.astro';
---

<Layout title="Brand Guidelines - Wellmade" description="Brand guidelines, logos, colors, and typography for Wellmade.">
  <!-- Hero -->
  <section class="section-primary py-20 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">Brand Guidelines</h1>
      <p class="text-lg md:text-xl text-white/80">
        Everything you need to represent Wellmade consistently across any medium.
      </p>
    </div>
  </section>

  <!-- Logo -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Logo</h2>
      <p class="text-lg text-body mb-12">
        The Wellmade logo is a hand-drawn wordmark paired with a distinctive dot. It comes in full wordmark and square (W) icon variants.
      </p>

      <!-- Full wordmark -->
      <h3 class="text-xl font-bold text-title mb-6">Wordmark</h3>
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        <div class="bg-white border border-light rounded-2xl p-10 flex items-center justify-center">
          <img src="/brand/Wellmade.svg" alt="Wellmade logo" class="max-w-full h-16" />
        </div>
        <div class="bg-primary rounded-2xl p-10 flex items-center justify-center">
          <img src="/brand/Wellmade-black.svg" alt="Wellmade logo on dark" class="max-w-full h-16 invert" />
        </div>
        <div class="bg-white border border-light rounded-2xl p-10 flex items-center justify-center">
          <img src="/brand/Wellmade-color.svg" alt="Wellmade color logo" class="max-w-full h-16" />
        </div>
        <div class="bg-title rounded-2xl p-10 flex items-center justify-center">
          <img src="/brand/Wellmade-black.svg" alt="Wellmade black logo" class="max-w-full h-16" />
        </div>
      </div>

      <!-- Square icon -->
      <h3 class="text-xl font-bold text-title mb-6">Square Icon</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="bg-white border border-light rounded-2xl p-8 flex items-center justify-center">
          <img src="/brand/Square.svg" alt="Wellmade square icon" class="w-20 h-20" />
        </div>
        <div class="bg-primary rounded-2xl p-8 flex items-center justify-center">
          <img src="/brand/Square-black.svg" alt="Wellmade square icon on dark" class="w-20 h-20 invert" />
        </div>
        <div class="bg-white border border-light rounded-2xl p-8 flex items-center justify-center">
          <img src="/brand/Square-color.svg" alt="Wellmade square color icon" class="w-20 h-20" />
        </div>
        <div class="bg-title rounded-2xl p-8 flex items-center justify-center">
          <img src="/brand/Square-black.svg" alt="Wellmade square black icon" class="w-20 h-20" />
        </div>
      </div>

      <!-- Download -->
      <div class="bg-light/30 rounded-2xl p-8">
        <h3 class="text-lg font-bold text-title mb-3">Download</h3>
        <p class="text-body mb-4">All logo variants are available in SVG and PNG formats.</p>
        <div class="flex flex-wrap gap-3">
          <a href="/brand/Wellmade.svg" download class="inline-block bg-primary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-primary/90 transition-colors">Wordmark SVG</a>
          <a href="/brand/Wellmade.png" download class="inline-block bg-primary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-primary/90 transition-colors">Wordmark PNG</a>
          <a href="/brand/Square.svg" download class="inline-block bg-primary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-primary/90 transition-colors">Icon SVG</a>
          <a href="/brand/Square.png" download class="inline-block bg-primary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-primary/90 transition-colors">Icon PNG</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Colors -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Colors</h2>
      <p class="text-lg text-body mb-12">
        Our palette is built around a deep purple primary and a light cyan accent, kept grounded with neutral grays.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <!-- Primary -->
        <div>
          <div class="bg-primary rounded-2xl h-32 mb-4 shadow-card"></div>
          <p class="font-bold text-title">Primary</p>
          <p class="text-body text-sm">#47446B</p>
          <p class="text-body text-sm">rgb(71, 68, 107)</p>
        </div>

        <!-- Accent -->
        <div>
          <div class="bg-accent rounded-2xl h-32 mb-4 shadow-card"></div>
          <p class="font-bold text-title">Accent</p>
          <p class="text-body text-sm">#B1E5F2</p>
          <p class="text-body text-sm">rgb(177, 229, 242)</p>
        </div>

        <!-- Light -->
        <div>
          <div class="bg-light rounded-2xl h-32 mb-4 shadow-card"></div>
          <p class="font-bold text-title">Light</p>
          <p class="text-body text-sm">#E8E9F3</p>
          <p class="text-body text-sm">rgb(232, 233, 243)</p>
        </div>

        <!-- Title -->
        <div>
          <div class="bg-title rounded-2xl h-32 mb-4 shadow-card"></div>
          <p class="font-bold text-title">Title</p>
          <p class="text-body text-sm">#2F2F2F</p>
          <p class="text-body text-sm">rgb(47, 47, 47)</p>
        </div>

        <!-- Body -->
        <div>
          <div class="bg-body rounded-2xl h-32 mb-4 shadow-card"></div>
          <p class="font-bold text-title">Body</p>
          <p class="text-body text-sm">#6D6D6D</p>
          <p class="text-body text-sm">rgb(109, 109, 109)</p>
        </div>

        <!-- White -->
        <div>
          <div class="bg-white rounded-2xl h-32 mb-4 shadow-card border border-light"></div>
          <p class="font-bold text-title">White</p>
          <p class="text-body text-sm">#FFFFFF</p>
          <p class="text-body text-sm">rgb(255, 255, 255)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Typography</h2>
      <p class="text-lg text-body mb-12">
        We use two typefaces: Josefin Sans for all primary text and Indie Flower for accents and taglines.
      </p>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Josefin Sans -->
        <div>
          <p class="text-sm font-bold text-primary uppercase tracking-wider mb-4">Primary Typeface</p>
          <div class="bg-white p-8 rounded-2xl shadow-card">
            <p class="text-4xl font-bold text-title mb-2">Josefin Sans</p>
            <p class="text-lg text-body mb-6">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br />abcdefghijklmnopqrstuvwxyz<br />0123456789</p>
            <div class="space-y-2 border-t border-light pt-4">
              <p class="text-title font-light">Light 300</p>
              <p class="text-title font-normal">Regular 400</p>
              <p class="text-title font-medium">Medium 500</p>
              <p class="text-title font-semibold">Semibold 600</p>
              <p class="text-title font-bold">Bold 700</p>
            </div>
            <a href="https://fonts.google.com/specimen/Josefin+Sans" target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">View on Google Fonts &rarr;</a>
          </div>
        </div>

        <!-- Indie Flower -->
        <div>
          <p class="text-sm font-bold text-primary uppercase tracking-wider mb-4">Accent Typeface</p>
          <div class="bg-white p-8 rounded-2xl shadow-card">
            <p class="text-4xl font-cursive text-title mb-2">Indie Flower</p>
            <p class="text-lg font-cursive text-body mb-6">ABCDEFGHIJKLMNOPQRSTUVWXYZ<br />abcdefghijklmnopqrstuvwxyz<br />0123456789</p>
            <div class="border-t border-light pt-4">
              <p class="font-cursive text-body">Used for taglines, accent text, and handwritten-feel elements.</p>
            </div>
            <a href="https://fonts.google.com/specimen/Indie+Flower" target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">View on Google Fonts &rarr;</a>
          </div>
        </div>
      </div>

      <!-- Type Scale -->
      <div class="mt-12">
        <p class="text-sm font-bold text-primary uppercase tracking-wider mb-4">Type Scale</p>
        <div class="bg-white p-8 rounded-2xl shadow-card space-y-4">
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">7xl</span>
            <span class="text-7xl font-bold text-title leading-none">80px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">6xl</span>
            <span class="text-6xl font-bold text-title leading-none">64px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">5xl</span>
            <span class="text-5xl font-bold text-title leading-none">52px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">4xl</span>
            <span class="text-4xl font-bold text-title leading-none">40px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">3xl</span>
            <span class="text-3xl font-bold text-title leading-none">32px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">2xl</span>
            <span class="text-2xl font-bold text-title leading-none">26px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">xl</span>
            <span class="text-xl text-title leading-none">22px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">lg</span>
            <span class="text-lg text-title leading-none">20px</span>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-sm text-body w-16 shrink-0">base</span>
            <span class="text-base text-title leading-none">18px</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Logo Usage Rules -->
  <section class="section-alt py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Logo Usage</h2>
      <p class="text-lg text-body mb-12">
        A few rules to keep the logo looking its best.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-primary mb-3">Clear Space</h3>
          <p class="text-body">Maintain clear space around the logo equal to the height of the dot mark. Don't crowd it with other elements.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-primary mb-3">Minimum Size</h3>
          <p class="text-body">The full wordmark should not be used smaller than 100px wide. The square icon should not be used smaller than 24px.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-primary mb-3">Backgrounds</h3>
          <p class="text-body">Use the color variant on white/light backgrounds. Use the white/inverted variant on dark or primary-colored backgrounds.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-card">
          <h3 class="text-xl font-bold text-primary mb-3">Don'ts</h3>
          <p class="text-body">Don't rotate, stretch, add effects, change the colors, or alter the proportions of the logo in any way.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Voice & Tone -->
  <section class="section-light py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-title mb-4">Voice & Tone</h2>
      <p class="text-lg text-body mb-12">
        How we sound is part of who we are.
      </p>

      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-bold text-title mb-2">Direct</h3>
          <p class="text-lg text-body">We say what we mean. Short sentences. No jargon. No fluff. If something is complicated, we make it simple.</p>
        </div>

        <div>
          <h3 class="text-xl font-bold text-title mb-2">Confident, not arrogant</h3>
          <p class="text-lg text-body">We know what we're good at and we're not shy about it. But we're here to help, not to show off.</p>
        </div>

        <div>
          <h3 class="text-xl font-bold text-title mb-2">Human</h3>
          <p class="text-lg text-body">We talk like people, not brands. We care about real problems, real users, real outcomes.</p>
        </div>

        <div>
          <h3 class="text-xl font-bold text-title mb-2">Builders' energy</h3>
          <p class="text-lg text-body">We're makers at heart. Our writing should feel like it comes from people who ship things, not people who just talk about it.</p>
        </div>
      </div>

      <div class="mt-12 bg-white p-8 rounded-2xl shadow-card">
        <p class="text-sm font-bold text-primary uppercase tracking-wider mb-4">Tagline</p>
        <p class="text-3xl font-cursive text-primary">Lean builders. We deliver.</p>
      </div>
    </div>
  </section>

  <Tagline text="Wellmade. Lean builders. We deliver." />
</Layout>
