---
import signatures from '../../data/signatures.json';
---

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex, nofollow">
  <title>Email Signatures - Wellmade</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      max-width: 600px;
      margin: 40px auto;
      padding: 20px;
      color: #47446B;
    }
    h1 {
      font-size: 24px;
      margin-bottom: 8px;
    }
    p {
      color: #666;
      margin-bottom: 32px;
    }
    .member {
      border: 1px solid #eee;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 16px;
    }
    .member h2 {
      font-size: 16px;
      margin: 0 0 4px 0;
    }
    .member .title {
      font-size: 14px;
      color: #666;
      margin-bottom: 12px;
    }
    .member a {
      display: inline-block;
      background: #47446B;
      color: white;
      padding: 8px 16px;
      border-radius: 4px;
      text-decoration: none;
      font-size: 14px;
    }
    .member a:hover {
      background: #5a577a;
    }
    .instructions {
      background: #f5f5f5;
      padding: 16px;
      border-radius: 8px;
      margin-top: 32px;
      font-size: 14px;
    }
    .instructions h3 {
      margin-top: 0;
      font-size: 14px;
    }
    .instructions ol {
      margin: 0;
      padding-left: 20px;
    }
  </style>
</head>
<body>
  <h1>Email Signatures</h1>
  <p>Select a team member to view their email signature.</p>

  {signatures.map((member) => (
    <div class="member">
      <h2>{member.name}</h2>
      <div class="title">{member.title}</div>
      <a href={`/signatures/${member.id}/`}>View Signature</a>
    </div>
  ))}

  <div class="instructions">
    <h3>How to use</h3>
    <ol>
      <li>Click on "View Signature" to open the signature</li>
      <li>Select all (Cmd+A / Ctrl+A)</li>
      <li>Copy (Cmd+C / Ctrl+C)</li>
      <li>Paste into your email client's signature settings</li>
    </ol>
  </div>
</body>
</html>
