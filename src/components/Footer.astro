---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { href: '/services/product-development', label: 'Product Development' },
    { href: '/services/ai-integration', label: 'AI Integration' },
    { href: '/services/devops-infrastructure', label: 'DevOps & Infrastructure' },
    { href: '/services/discovery-strategy', label: 'Discovery & Strategy' },
    { href: '/services/rescue-refactor', label: 'Rescue & Refactor' },
  ],
  company: [
    { href: '/manifesto', label: 'Manifesto' },
    { href: '/approach', label: 'Approach' },
    { href: '/working-with-us', label: 'Working With Us' },
    { href: '/partnerships', label: 'Partnerships' },
  ],
};
---

<footer class="bg-primary text-white">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 md:gap-8">
      <!-- Logo and tagline -->
      <div class="lg:col-span-1">
        <Logo class="w-40 h-auto mb-6 text-white" animated={false} monochrome={true} />
        <p class="text-white/70 text-sm leading-relaxed mb-6">
          Products that work.<br />
          Teams that deliver.
        </p>
        <p class="text-accent font-cursive text-lg">
          Innovation with a vision.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wider mb-4">Services</h4>
        <ul class="space-y-3">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wider mb-4">Company</h4>
        <ul class="space-y-3">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-sm uppercase tracking-wider mb-4">Get in Touch</h4>
        <p class="text-white/70 text-sm mb-4">
          No pitch deck needed. Let's see if there's a fit.
        </p>
        <a href="/contact" class="inline-block bg-white text-primary px-6 py-2.5 rounded-full font-semibold hover:bg-accent transition-colors text-sm">
          Let's talk
        </a>
        <div class="mt-6">
          <a href="mailto:hello@wellmade.be" class="text-white/70 hover:text-white transition-colors text-sm">
            hello@wellmade.be
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/20 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-4">
        <p class="text-white/50 text-xs">
          &copy; {currentYear} Wellmade. Lean builders. We deliver.
        </p>
        <span class="hidden md:inline text-white/30 text-xs">·</span>
        <div class="flex gap-4">
          <a href="/privacy-policy" class="text-white/50 hover:text-white transition-colors text-xs">Privacy Policy</a>
          <a href="/terms-of-service" class="text-white/50 hover:text-white transition-colors text-xs">Terms of Service</a>
        </div>
      </div>
      <div class="flex gap-6">
        <a href="https://www.linkedin.com/company/wellmadestudio/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://github.com/wellmade-studio" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
