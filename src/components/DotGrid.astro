---
interface Props {
  class?: string;
  color?: string;
  opacity?: number;
  size?: number;
  spacing?: number;
}

const {
  class: className = '',
  color = '#47446B',
  opacity = 0.15,
  size = 1.5,
  spacing = 28,
} = Astro.props;

const patternId = `dot-grid-${Math.random().toString(36).slice(2, 9)}`;
---

<svg
  class:list={['pointer-events-none absolute inset-0 w-full h-full', className]}
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <pattern id={patternId} x="0" y="0" width={spacing} height={spacing} patternUnits="userSpaceOnUse">
      <circle cx={spacing / 2} cy={spacing / 2} r={size} fill={color} opacity={opacity} />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${patternId})`} />
</svg>
