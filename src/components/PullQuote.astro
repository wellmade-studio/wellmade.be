---
interface Props {
  accent?: boolean;
  cursive?: boolean;
  onDark?: boolean;
  class?: string;
}

const { accent = false, cursive = false, onDark = false, class: className = '' } = Astro.props;
---

<figure class:list={['my-10 md:my-14 pl-6 md:pl-10 border-l-4 relative', accent ? 'border-accent' : 'border-primary', className]}>
  <svg
    class:list={['absolute -top-4 -left-3 w-10 h-10', accent ? 'text-accent' : 'text-primary', 'opacity-30']}
    fill="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path d="M7.17 6.17A5 5 0 002 11v7h7v-7H5.5a3.5 3.5 0 013.5-3.5V5a1 1 0 00-1.83-.83zM16.17 6.17A5 5 0 0011 11v7h7v-7h-3.5a3.5 3.5 0 013.5-3.5V5a1 1 0 00-1.83-.83z"/>
  </svg>
  <blockquote class:list={[
    'leading-snug',
    cursive
      ? (onDark ? 'font-cursive text-3xl md:text-4xl text-accent' : 'font-cursive text-3xl md:text-4xl text-primary')
      : (onDark ? 'text-2xl md:text-3xl font-bold text-white' : 'text-2xl md:text-3xl font-bold text-title'),
  ]}>
    <slot />
  </blockquote>
</figure>
