---
interface Stat {
  value: string;
  label: string;
  suffix?: string;
}

interface Props {
  stats: Stat[];
  class?: string;
}

const { stats, class: className = '' } = Astro.props;
---

<div class:list={['grid gap-8 md:gap-12', stats.length === 4 ? 'grid-cols-2 md:grid-cols-4' : 'grid-cols-2 md:grid-cols-3', className]}>
  {stats.map((stat) => (
    <div class="text-center">
      <div class="text-5xl md:text-6xl font-bold text-primary leading-none mb-2">
        {stat.value}<span class="text-3xl md:text-4xl text-accent">{stat.suffix}</span>
      </div>
      <div class="text-body text-sm md:text-base uppercase tracking-wider">{stat.label}</div>
    </div>
  ))}
</div>
